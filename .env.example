# ============================================
# Event Check-In System - Environment Config
# ============================================
# Copy this file to .env and fill in the values

# --- Google OAuth 2.0 (Staff Login) ---
# From Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Must match the authorized redirect URI in Google OAuth settings
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- Google Service Account (Sheets API Access) ---
# From Google Cloud Console > IAM & Admin > Service Accounts
# Create a service account, generate a JSON key, and extract these values
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the full private_key value from the JSON key file (including -----BEGIN...-----END blocks)
# The newlines should be literal \n in this file
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_SERVICE_ACCOUNT_TOKEN_URI=https://oauth2.googleapis.com/token

# --- Google Sheets Configuration ---
# The spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
GOOGLE_SHEET_ID=1FMQiTsHl1msFVpgcB4aymvxwtkLGR0ulo4UhckCAhdk
# The tab/sheet name (defaults to "Sheet1" if not set)
GOOGLE_SHEET_NAME=Sheet1

# --- Staff Authorization ---
# Comma-separated list of Gmail addresses allowed to access the system
STAFF_EMAILS=admin@example.com,staff1@example.com,staff2@example.com

# --- JWT Configuration ---
# A random secret key for signing JWT tokens (generate with: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-random-secret-key

# --- Server Configuration ---
# The public URL where this server is accessible (used for QR code generation)
SERVER_URL=http://localhost:3000
# Server host binding (default: 0.0.0.0)
HOST=0.0.0.0
# Server port (default: 3000)
PORT=3000

# --- Logging ---
# Set RUST_LOG for tracing (e.g., info,debug,trace)
# RUST_LOG=event_checkin=info,tower_http=debug
